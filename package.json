{
  "name": "home-energy-battery",
  "version": "0.1.0",
  "private": true,
  "description": "ECHONET Lite tools for local HEMS energy devices.",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "node:help": "node home-energy-battery-node.js --help",
    "start": "node server.js",
    "check": "node --check home-energy-battery-node.js && node --check server.js && node --check public/app.js && node --check public/lib.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import ./tests/setup-timezone.js --test"
  },
  "dependencies": {
    "node-echonet-lite": "^0.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.1"
  }
}
